# ======================
# 1. Java 后端相关（mf-fertilizer）
# ======================
# 编译产物（每次运行都会生成，提交只会乱仓库）
*.class
*.jar
*.war
target/
build/
out/

# IDEA 本地配置文件（只和你电脑环境有关，别人拉取不需要）
.idea/
*.iml
*.iws
*.ipr
mf-fertilizer/.idea/

# ======================
# 2. 前端相关（mf-frontend / mf-frontend-client）
# ======================
# 依赖包和构建产物
node_modules/
dist/
npm-debug.log*
yarn-error.log*

# ======================
# 3. 工具和临时文件
# ======================
# Claude 本地配置
.claude/settings.local.json
.claude/.cache/

# 系统/编辑器临时文件
.DS_Store
Thumbs.db
*.swp
*~

# 本地配置文件（比如 application.yml 本地修改）
application.yml.local
application-dev.yml

# Python 字节码缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 虚拟环境目录
venv/
env/
*.venv/

# Chroma 向量数据库文件
mf-ai/data/chroma_db/
# 如果你的项目中还有其他 chroma_db，直接写下面这行也通用
# chroma_db/

# 其他临时/无关文件
*.log
.DS_Store
Thumbs.db